# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database Configuration
DATABASE_URL=jdbc:postgresql://postgres:5432/coffe_nerd
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change_me_in_production

# JWT Configuration
JWT_SECRET=change_me_with_a_secure_secret_key_at_least_32_characters_long
JWT_EXPIRATION=86400000

# Logging
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_NERDCOFFE=INFO

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info

# Application Name
SPRING_APPLICATION_NAME=coffe-nerd
